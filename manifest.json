{
  "manifest_version": 3,
  "name": "AO3 Analytic Tracker",
  "version": "1.0",

  "permissions": ["storage", "alarms"],

  "content_scripts": [
    {
      "matches": ["https://archiveofourown.org/*"],
      "js": ["scripts/main.js"]
    }
  ],

  "background": {
    "service_worker": "scripts/background.js"
  }
}