{
  "manifest_version": 3,
  "name": "AO3 Analytic Tracker",
  "description": "Tracks a work's stat overtime",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "alarms", "scripting", "tabs"],

  "content_scripts": [
    {
      "matches": ["https://archiveofourown.org/*"],
      "js": ["dashboard_script.js"]
    }
  ],

  "background": {
    "service_worker": "background_script.js"
  }
}